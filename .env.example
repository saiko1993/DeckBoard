# Copy this file to .env and fill in your values
# DO NOT commit .env to source control

# Apple Developer Account
APPLE_ID=your.apple.id@email.com
TEAM_ID=XXXXXXXXXX
ITC_TEAM_ID=XXXXXXXXXX
APP_APPLE_ID=1234567890

# Match (Certificate Storage)
MATCH_GIT_URL=https://github.com/your-org/match-repo.git
MATCH_PASSWORD=your-match-passphrase

# Build Configuration
PROVISIONING_PROFILE_SPECIFIER=match Development com.deskboard.app

# Optional: DeskBoard Push Wake Gateway
# Configure in-app from Settings > Background Wake
PUSH_GATEWAY_URL=https://deskboard-push-gateway.<your-subdomain>.workers.dev
PUSH_GATEWAY_API_KEY=your-secret-api-key

# Optional: DeskBoard Mac Receiver Relay
# Configure in-app from Settings > Mac Receiver Relay
MAC_RELAY_URL=http://192.168.1.20:7788
MAC_RELAY_API_KEY=your-mac-relay-key
