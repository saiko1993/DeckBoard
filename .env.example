# Copy this file to .env and fill in your values
# DO NOT commit .env to source control

# Apple Developer Account
APPLE_ID=your.apple.id@email.com
TEAM_ID=XXXXXXXXXX
ITC_TEAM_ID=XXXXXXXXXX
APP_APPLE_ID=1234567890

# Match (Certificate Storage)
MATCH_GIT_URL=https://github.com/your-org/match-repo.git
MATCH_PASSWORD=your-match-passphrase

# API Configuration (also set in Info.plist for the app)
API_BASE_URL=https://api.internalcomm.yourcompany.com/v1
WS_BASE_URL=wss://ws.internalcomm.yourcompany.com
API_VERSION=1

# Build Configuration
PROVISIONING_PROFILE_SPECIFIER=match Development com.internalcomm.app