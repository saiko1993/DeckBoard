# frozen_string_literal: true
require "shellwords"

# =============================================================================
# DeskBoard - Fastfile
# Automates building, testing, and distributing the DeskBoard iOS app.
#
# Prerequisites:
#   - Xcode Command Line Tools installed
#   - Ruby + Bundler: `gem install bundler && bundle install`
#   - Mint (Swift tools): `brew install mint && mint bootstrap`
#   - Environment variables set (see .env.example)
#
# Usage:
#   bundle exec fastlane <lane>
# =============================================================================

default_platform(:ios)

APP_IDENTIFIER = ENV["APP_BUNDLE_IDENTIFIER"] || "app.rork.qk8s5pz3bbw4sk3nw0gmq"
APP_CONTROLS_IDENTIFIER = ENV["APP_CONTROLS_BUNDLE_IDENTIFIER"] || "#{APP_IDENTIFIER}.controls"
SCHEME         = "DeskBoard"
WORKSPACE      = "DeskBoard.xcworkspace"
PROJECT        = "DeskBoard.xcodeproj"
TARGET_APP     = "DeskBoard"
TARGET_CONTROLS = "DeskBoardControls"

def extract_build_setting(raw, key)
  line = raw.lines.find { |item| item.strip.start_with?("#{key} =") }
  return nil unless line
  line.split("=", 2).last.to_s.strip
end

platform :ios do
  private_lane :signing_preflight do |options|
    profile_type = (options[:profile_type] || "AppStore").to_s
    require_env_profiles = options[:require_env_profiles] == true || ENV["CI"].to_s.downcase == "true"
    app_id = APP_IDENTIFIER.to_s.strip
    controls_id = APP_CONTROLS_IDENTIFIER.to_s.strip
    forbidden_token = ["sound", "grabshare"].join

    UI.user_error!("APP_IDENTIFIER is empty") if app_id.empty?
    UI.user_error!("APP_CONTROLS_IDENTIFIER is empty") if controls_id.empty?
    UI.user_error!("Forbidden bundle ID token detected") if app_id.include?(forbidden_token) || controls_id.include?(forbidden_token)
    UI.user_error!("Controls bundle id must be under app root and end with .controls") unless controls_id == "#{app_id}.controls"

    app_profile = "match #{profile_type} #{app_id}"
    controls_profile = "match #{profile_type} #{controls_id}"
    UI.user_error!("App and controls profiles must differ for manual split signing") if app_profile == controls_profile
    UI.user_error!("Forbidden profile token detected") if app_profile.include?(forbidden_token) || controls_profile.include?(forbidden_token)

    if require_env_profiles
      app_profile_env = ENV["PROVISIONING_PROFILE_SPECIFIER"].to_s.strip
      controls_profile_env = ENV["PROVISIONING_PROFILE_SPECIFIER_DESKBOARDCONTROLS"].to_s.strip
      UI.user_error!("Missing env PROVISIONING_PROFILE_SPECIFIER in CI") if app_profile_env.empty?
      UI.user_error!("Missing env PROVISIONING_PROFILE_SPECIFIER_DESKBOARDCONTROLS in CI") if controls_profile_env.empty?
      UI.user_error!("CI profile specifiers must be different (app vs controls)") if app_profile_env == controls_profile_env
      UI.user_error!("Forbidden profile token detected in CI env") if app_profile_env.include?(forbidden_token) || controls_profile_env.include?(forbidden_token)
    end

    project_path = File.expand_path("../#{PROJECT}", __dir__)
    app_settings = sh("xcodebuild -project #{project_path.shellescape} -target #{TARGET_APP.shellescape} -configuration Release -showBuildSettings")
    controls_settings = sh("xcodebuild -project #{project_path.shellescape} -target #{TARGET_CONTROLS.shellescape} -configuration Release -showBuildSettings")

    app_bundle_setting = extract_build_setting(app_settings, "PRODUCT_BUNDLE_IDENTIFIER")
    controls_bundle_setting = extract_build_setting(controls_settings, "PRODUCT_BUNDLE_IDENTIFIER")
    app_code_sign_style = extract_build_setting(app_settings, "CODE_SIGN_STYLE")
    controls_code_sign_style = extract_build_setting(controls_settings, "CODE_SIGN_STYLE")

    UI.user_error!("Release app bundle id mismatch: expected #{app_id}, got #{app_bundle_setting}") unless app_bundle_setting == app_id
    UI.user_error!("Release controls bundle id mismatch: expected #{controls_id}, got #{controls_bundle_setting}") unless controls_bundle_setting == controls_id
    UI.user_error!("Release app CODE_SIGN_STYLE must be Manual") unless app_code_sign_style == "Manual"
    UI.user_error!("Release controls CODE_SIGN_STYLE must be Manual") unless controls_code_sign_style == "Manual"

    repo_root = File.expand_path("..", __dir__)
    forbidden_refs = sh("cd #{repo_root.shellescape} && rg -n #{forbidden_token.shellescape} . || true").to_s.strip
    UI.user_error!("Found forbidden legacy token references:\n#{forbidden_refs}") unless forbidden_refs.empty?

    UI.success("✅ Signing preflight passed for #{profile_type}")
  end

  # ---------------------------------------------------------------------------
  # Setup
  # ---------------------------------------------------------------------------

  desc "Generate Xcode project using XcodeGen"
  lane :generate do
    sh("mint run xcodegen generate --spec ../project.yml")
    UI.success("✅ Xcode project generated successfully")
  end

  desc "Install all dependencies (SPM, Mint tools, Ruby gems)"
  lane :setup do
    generate
    sh("cd .. && swift package resolve") if File.exist?("../Package.resolved")
    UI.success("✅ Dependencies installed and project ready")
  end

  # ---------------------------------------------------------------------------
  # Code Quality
  # ---------------------------------------------------------------------------

  desc "Run SwiftLint to check code style"
  lane :lint do
    swiftlint(
      mode: :lint,
      config_file: ".swiftlint.yml",
      raise_if_swiftlint_error: true,
      ignore_exit_status: false
    )
  end

  desc "Run SwiftFormat to auto-format code"
  lane :format do
    sh("mint run swiftformat --config ../.swiftformat ../Sources ../Tests")
  end

  # ---------------------------------------------------------------------------
  # Testing
  # ---------------------------------------------------------------------------

  desc "Run unit tests"
  lane :test do
    generate unless File.exist?("../#{PROJECT}")

    run_tests(
      project: PROJECT,
      scheme: SCHEME,
      devices: [ENV["TEST_DEVICE"] || "iPhone 16 Pro"],
      clean: true,
      code_coverage: true,
      output_directory: "fastlane/test_output",
      output_types: "html,junit",
      fail_build: true
    )

    UI.success("✅ All tests passed")
  end

  # ---------------------------------------------------------------------------
  # Certificates & Provisioning (using Match)
  # ---------------------------------------------------------------------------

  desc "Sync development certificates and provisioning profiles"
  lane :sync_dev_certs do
    match(
      type: "development",
      app_identifier: [APP_IDENTIFIER, APP_CONTROLS_IDENTIFIER],
      readonly: is_ci
    )
  end

  desc "Sync distribution certificates and provisioning profiles"
  lane :sync_dist_certs do
    match(
      type: "appstore",
      app_identifier: [APP_IDENTIFIER, APP_CONTROLS_IDENTIFIER],
      readonly: is_ci
    )
  end

  desc "Sync AdHoc certificates and provisioning profiles"
  lane :sync_adhoc_certs do
    match(
      type: "adhoc",
      app_identifier: [APP_IDENTIFIER, APP_CONTROLS_IDENTIFIER],
      readonly: is_ci
    )
  end

  # ---------------------------------------------------------------------------
  # Building
  # ---------------------------------------------------------------------------

  desc "Build the app for development (Debug)"
  lane :build_debug do
    generate unless File.exist?("../#{PROJECT}")
    signing_preflight(profile_type: "Development")
    sync_dev_certs

    gym(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Debug",
      export_method: "development",
      output_directory: "build",
      output_name: "DeskBoard-Debug.ipa",
      include_symbols: true,
      include_bitcode: false,
      xcargs: [
        "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']}",
        "PROVISIONING_PROFILE_SPECIFIER=match Development #{APP_IDENTIFIER}",
        "PROVISIONING_PROFILE_SPECIFIER_DESKBOARDCONTROLS=match Development #{APP_CONTROLS_IDENTIFIER}"
      ].join(" ")
    )

    UI.success("✅ Debug build complete")
  end

  desc "Build the app for AdHoc distribution"
  lane :build_adhoc do
    generate unless File.exist?("../#{PROJECT}")
    signing_preflight(profile_type: "AdHoc")
    sync_adhoc_certs

    gym(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "ad-hoc",
      output_directory: "build",
      output_name: "DeskBoard-AdHoc.ipa",
      include_symbols: true,
      include_bitcode: false,
      xcargs: [
        "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']}",
        "PROVISIONING_PROFILE_SPECIFIER=match AdHoc #{APP_IDENTIFIER}",
        "PROVISIONING_PROFILE_SPECIFIER_DESKBOARDCONTROLS=match AdHoc #{APP_CONTROLS_IDENTIFIER}"
      ].join(" ")
    )

    UI.success("✅ AdHoc build complete")
  end

  desc "Build the app for App Store release"
  lane :build_release do
    generate unless File.exist?("../#{PROJECT}")
    signing_preflight(profile_type: "AppStore")
    sync_dist_certs

    gym(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "DeskBoard-Release.ipa",
      include_symbols: true,
      include_bitcode: false,
      xcargs: [
        "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']}",
        "PROVISIONING_PROFILE_SPECIFIER=match AppStore #{APP_IDENTIFIER}",
        "PROVISIONING_PROFILE_SPECIFIER_DESKBOARDCONTROLS=match AppStore #{APP_CONTROLS_IDENTIFIER}"
      ].join(" ")
    )

    UI.success("✅ Release build complete")
  end

  # ---------------------------------------------------------------------------
  # Distribution
  # ---------------------------------------------------------------------------

  desc "Deploy to TestFlight for internal testing"
  lane :beta do
    ensure_git_status_clean unless is_ci
    increment_build_number(xcodeproj: PROJECT)
    build_release
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id: ENV["APP_APPLE_ID"],
      ipa: "build/DeskBoard-Release.ipa"
    )
    UI.success("✅ Uploaded to TestFlight")
  end

  desc "Deploy to App Store"
  lane :release do
    ensure_git_status_clean
    increment_build_number(xcodeproj: PROJECT)
    build_release
    upload_to_app_store(
      ipa: "build/DeskBoard-Release.ipa",
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: false,
      automatic_release: false
    )
    UI.success("✅ Uploaded to App Store")
  end

  # ---------------------------------------------------------------------------
  # Utilities
  # ---------------------------------------------------------------------------

  desc "Increment build number"
  lane :bump_build do
    increment_build_number(xcodeproj: PROJECT)
    commit_version_bump(
      xcodeproj: PROJECT,
      message: "chore: bump build number to #{get_build_number(xcodeproj: PROJECT)}"
    )
  end

  desc "Increment version number (type: patch|minor|major)"
  lane :bump_version do |options|
    bump_type = options[:type] || "patch"
    increment_version_number(
      bump_type: bump_type,
      xcodeproj: PROJECT
    )
    increment_build_number(xcodeproj: PROJECT)
    commit_version_bump(
      xcodeproj: PROJECT,
      message: "chore: bump version to #{get_version_number(xcodeproj: PROJECT)}"
    )
  end

  desc "Clean build artifacts"
  lane :clean do
    sh("rm -rf ../build")
    sh("rm -rf ../DerivedData")
    clear_derived_data
    UI.success("✅ Build artifacts cleaned")
  end

  # ---------------------------------------------------------------------------
  # Error handling
  # ---------------------------------------------------------------------------
  error do |lane, exception|
    UI.error("❌ Error in lane #{lane}: #{exception.message}")
  end
end
